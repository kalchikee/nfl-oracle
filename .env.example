# NFL Oracle v4.0 — Environment Variables
# Copy this to .env and fill in values (never commit .env to git)

# ── Required ──────────────────────────────────────────────────────────────────
# Discord webhook URL for picks and recap messages
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_TOKEN

# ── Optional ──────────────────────────────────────────────────────────────────
# The Odds API (free tier: 500 req/month) — provides sharper Vegas lines
# Sign up at https://the-odds-api.com/
# Without this, the system uses ESPN's embedded odds (usually available by Wednesday)
ODDS_API_KEY=

# ── Dev / Debug ───────────────────────────────────────────────────────────────
LOG_LEVEL=info          # debug | info | warn | error
LOG_FORMAT=             # Set to "json" in production (GitHub Actions sets this automatically)
CACHE_TTL_HOURS=4       # How long to cache ESPN API responses (hours)
DB_PATH=./data/nfl_oracle.db
CACHE_DIR=./cache
